# Comma-separated list of profile names to expose to the agent.
# Each name must have matching DB_<NAME>_* variables below.
# The env prefix (e.g. DB_PG_LOCAL) is the server-side operator key.
# Set DB_<NAME>_ALIAS to expose a different MCP-facing identifier to agents.
DB_PROFILES=

# ---------- Profile: PostgreSQL (server-scope) ----------
# Connects to the server (initial database is "postgres" by default, override with
# DB_<NAME>_INITIAL_DATABASE). Use ALLOWED_DATABASES to restrict what the agent may
# query. Set REQUIRE_QUALIFIED_DATABASE=true to require schema-qualified names
# (e.g. analytics.public.users).
# DB_PG_LOCAL_CLIENT=postgres
# DB_PG_LOCAL_HOST=localhost
# DB_PG_LOCAL_PORT=5432
# DB_PG_LOCAL_INITIAL_DATABASE=postgres
# DB_PG_LOCAL_USER=readonly_user
# DB_PG_LOCAL_PASSWORD=change_me
# DB_PG_LOCAL_SSL=false
# DB_PG_LOCAL_ALLOWED_DATABASES=app,analytics
# DB_PG_LOCAL_REQUIRE_QUALIFIED_DATABASE=true
# --- optional alias/display metadata (defaults to the operator key) ---
# DB_PG_LOCAL_ALIAS=bi_local
# DB_PG_LOCAL_DISPLAY_NAME=Local BI
# DB_PG_LOCAL_DESCRIPTION=Local read-only BI warehouse
# DB_PG_LOCAL_TAGS=bi, local
# DB_PG_LOCAL_CAPABILITIES=read-only

# ---------- Profile: MySQL / MariaDB (server-scope) ----------
# Initial database is "mysql" by default. Fully-qualified names look like
# `mydb`.`mytable`.
# DB_MYSQL_REPORTING_CLIENT=mysql
# DB_MYSQL_REPORTING_HOST=localhost
# DB_MYSQL_REPORTING_PORT=3306
# DB_MYSQL_REPORTING_INITIAL_DATABASE=mysql
# DB_MYSQL_REPORTING_USER=readonly_user
# DB_MYSQL_REPORTING_PASSWORD=change_me
# DB_MYSQL_REPORTING_ALLOWED_DATABASES=reporting,staging
# DB_MYSQL_REPORTING_REQUIRE_QUALIFIED_DATABASE=true
# --- optional alias/display metadata (defaults to the operator key) ---
# DB_MYSQL_REPORTING_ALIAS=reporting
# DB_MYSQL_REPORTING_DISPLAY_NAME=Reporting BI
# DB_MYSQL_REPORTING_DESCRIPTION=Reporting read-only BI warehouse
# DB_MYSQL_REPORTING_TAGS=bi, reporting
# DB_MYSQL_REPORTING_CAPABILITIES=read-only

# ---------- Profile: SQL Server / Azure SQL (server-scope) ----------
# Use TRUST_SERVER_CERTIFICATE=true when the server uses a self-signed
# certificate (common in on-prem Windows). For cross-database queries use
# three-part names like [catastral].[dbo].[Tabla].
# DB_SQLSERVER_BI_CLIENT=sqlserver
# DB_SQLSERVER_BI_HOST=10.10.0.12
# DB_SQLSERVER_BI_PORT=1433
# DB_SQLSERVER_BI_INITIAL_DATABASE=catastral
# DB_SQLSERVER_BI_USER=readonly_user
# DB_SQLSERVER_BI_PASSWORD=change_me
# DB_SQLSERVER_BI_ENCRYPT=true
# DB_SQLSERVER_BI_TRUST_SERVER_CERTIFICATE=true
# DB_SQLSERVER_BI_ALLOWED_DATABASES=catastral,catastro
# DB_SQLSERVER_BI_REQUIRE_QUALIFIED_DATABASE=true
# --- optional alias/display metadata (defaults to the operator key) ---
# DB_SQLSERVER_BI_ALIAS=bi_catastro
# DB_SQLSERVER_BI_DISPLAY_NAME=Catastro BI
# DB_SQLSERVER_BI_DESCRIPTION=Catastro read-only BI warehouse
# DB_SQLSERVER_BI_TAGS=bi, finance

# ---------- Profile: SQLite (database-scope) ----------
# Filename must be a relative path that stays inside the project root.
# DB_SQLITE_DEMO_CLIENT=sqlite
# DB_SQLITE_DEMO_FILENAME=./data/demo.sqlite
# DB_SQLITE_DEMO_ALLOWED_DATABASES=main

# ---------- Secret references (file-backed) ----------
# Any secret-bearing field (DB_<NAME>_PASSWORD today) can point at a file
# containing the secret value. The file MUST be an absolute path. The literal
# ${secret:file:...} is resolved at startup and never appears in logs, errors,
# or the agent-facing ProfileSummary. The filesystem read uses async I/O with a
# per-resolve timeout (default: 5s).
# Example:
# DB_SQLSERVER_BI_PASSWORD=${secret:file:/run/secrets/db_pw}

# ---------- Safety limits ----------
MAX_ROWS_DEFAULT=100
MAX_ROWS_HARD_LIMIT=1000
QUERY_TIMEOUT_MS_DEFAULT=10000
QUERY_TIMEOUT_MS_HARD_LIMIT=60000

# ---------- Transport (PR2) ----------
# Selects the wire transport. Allowed values:
#   stdio          (default — historical behavior, MCP host spawns a child process)
#   streamableHttp (opt-in — shared HTTP process behind a reverse proxy)
# Any other value fails fast at startup with a stderr message naming the
# allowed values. See apps/mcp-readonly-sql/README.md → "HTTP deployment".
# MCP_TRANSPORT=streamableHttp

# ---------- HTTP listener (only read when MCP_TRANSPORT=streamableHttp) ----------
# Bind address. Default 127.0.0.1 (loopback only). Binding a non-loopback
# address requires one of the opt-ins below.
# MCP_HTTP_HOST=127.0.0.1

# Port. Default 3001. Use distinct ports per MCP when several share a host
# (e.g. 3002, 3003 for future apps). Reverse proxy in front of the app
# MUST also enforce a body-size cap (client_max_body_size or equivalent).
# MCP_HTTP_PORT=3001

# Path the SDK transport serves. Default /mcp. /healthz is always served
# alongside at the same host:port (it is not path-scoped).
# MCP_HTTP_PATH=/mcp

# Stateless session mode (default true). When true, the shared HTTP base
# instantiates a fresh per-request transport so concurrent agents cannot
# leak sessions across each other (the SDK 1.29 transport keeps one
# sessionId per transport instance, so a cached transport is unsafe in
# multi-agent deployments). Set to false ONLY for single-agent
# deployments and expect documented single-agent semantics.
# MCP_HTTP_STATELESS=true

# Graceful shutdown timeout in ms (default 10000). When the drain phase
# exceeds this value, the process force-closes with exit 1.
# MCP_HTTP_SHUTDOWN_TIMEOUT_MS=10000

# Body-size cap in bytes (default 1048576 = 1 MiB). Requests with
# Content-Length > this limit are rejected with 413 BEFORE the SDK reads
# them. The reverse proxy MUST also enforce a cap on chunked bodies.
# MCP_HTTP_MAX_BODY_BYTES=1048576

# When false (the safe default), requests without a Content-Length
# header (chunked transfer-encoded bodies) are rejected with 411 Length
# Required. Operators that front the app with a reverse proxy that
# already enforces client_max_body_size MAY set this to true to accept
# chunked bodies; the shared base logs a one-shot warning on the first
# such request.
# MCP_HTTP_ALLOW_UNBOUNDED_BODY=false

# Log format for the HTTP path. "text" (default) writes one-line key=value
# pairs; "json" writes one-line JSON objects with ts/level/msg/agentId/
# requestId fields. stdout is reserved for the transport stream in HTTP
# mode; all log lines go to stderr.
# MCP_LOG_FORMAT=text

# Loopback opt-in. The shared base refuses to bind a non-loopback
# address unless one of the following is true:
#   MCP_HTTP_BEHIND_PROXY=true            (production: TLS terminated upstream)
#   MCP_HTTP_ALLOW_INSECURE_BIND=true     (dev/staging: explicit acknowledgement
#                                          that TLS is the operator's responsibility)
# The legacy MCP_HTTP_ALLOW_INSECURE_LOOPBACK is accepted as a deprecated
# alias of MCP_HTTP_ALLOW_INSECURE_BIND.

# ---------- Agent authorization (required for MCP_TRANSPORT=streamableHttp) ----------
# Opaque HMAC secret used to compute keyHash for every agent. MUST be at
# least 32 bytes of entropy. Generate with: openssl rand -hex 32
# The app exits non-zero at startup if this is missing or too short.
# MCP_AGENT_HMAC_SECRET=

# Path to a JSON file containing per-agent records, OR an inline JSON
# string. JSON file wins when both are set. Format:
#   [
#     {
#       "id": "third-party-x",
#       "keyHash": "<HMAC-SHA256(secret, token) as 64-char hex>",
#       "scopes": ["read:bi_catastro", "list:*"]
#     }
#   ]
# - id: stable string, opaque to the agent
# - keyHash: 64 lowercase/uppercase hex characters; the SHA-256 HMAC of
#   the agent's bearer token under MCP_AGENT_HMAC_SECRET
# - scopes: array of "<read|list|call>:<resource>" where <resource> is
#   "*" or an identifier matching [A-Za-z0-9_.-]+
# At least one agent is required when MCP_TRANSPORT=streamableHttp AND
# MCP_AUTHORITY_URL is unset (the local backend). The app fails closed
# on missing/malformed config.
# MCP_AGENTS_JSON=/etc/mcp/mcp-readonly-sql.agents.json
# MCP_AGENTS_INLINE=[{"id":"...","keyHash":"...","scopes":["read:*"]}]

# ---------- Choose your backend (Phase 1b — external-token-authority-verification) ----------
# When MCP_AUTHORITY_URL is UNSET, the app uses the local HMAC roster
# (LocalRosterAuthority). This is the dev/offline fallback. The local
# backend uses MCP_AGENT_HMAC_SECRET + MCP_AGENTS_JSON/INLINE above.
#
# When MCP_AUTHORITY_URL is SET, the app uses the external JWKS authority
# (JwksAuthority). This is the recommended default for production and
# shared deployments. The local roster is NOT required when the JWKS
# backend is selected — the authority issues and validates tokens.
#
# To switch backends, set or unset MCP_AUTHORITY_URL. The selection is
# deterministic and is reflected in `GET /healthz` as `authorityBackend`
# ("local" or "jwks"). See deploy/README.md → "Choose your backend".

# URL of the external authority (e.g. a sibling MCP that issues tokens,
# or a third-party identity provider). Setting this switches the app
# from the local HMAC roster to the JWKS authority.
# MCP_AUTHORITY_URL=https://auth.example.com

# The `aud` claim the authority issues tokens for. REQUIRED when
# MCP_AUTHORITY_URL is set. The app rejects a missing/empty audience
# at startup (fail-closed) so a token issued by the authority for
# any other audience cannot be accepted.
# MCP_AUTHORITY_AUDIENCE=mcp-readonly-sql

# JWKS endpoint URL. Optional — defaults to
# `${MCP_AUTHORITY_URL}/.well-known/jwks.json` (the OIDC convention).
# Set this explicitly when the authority's JWKS is at a non-standard
# path.
# MCP_AUTHORITY_JWKS_URL=https://auth.example.com/.well-known/jwks.json

# How long the cached JWKS is reused before a refetch is forced.
# Default 60. Lower for fast key rotation; higher to reduce load.
# MCP_AUTHORITY_JWKS_TTL_S=60

# Clock-skew leeway for `exp` and `nbf` claims, in seconds. Default 30.
# MCP_AUTHORITY_LEEWAY_S=30

# Per-fetch timeout for the JWKS endpoint, in milliseconds. Default
# 5000. Must be > 0. The app fails fast (exit non-zero) when the
# probe exceeds this window.
# MCP_AUTHORITY_FETCH_TIMEOUT_MS=5000
