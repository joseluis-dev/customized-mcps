# ---------- mcp-oauth-admin ----------
# The OAuth2 authority's HTTP listener. Defaults to loopback-only;
# binding a non-loopback address requires the same opt-ins as the
# other MCP apps (see apps/mcp-readonly-sql/.env.example).
# Port Allocation Convention: mcp-oauth-admin MUST default to 3002.
# Resource servers MUST NOT claim 3002 — it is reserved for the
# authority per the mcp-http-transport spec.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3002
MCP_HTTP_PATH=/admin

# Log format. "text" (default) writes one-line key=value pairs;
# "json" writes one-line JSON objects.
MCP_LOG_FORMAT=text

# ---------- Authority URL (advertised in OIDC discovery) ----------
# The public URL of THIS authority. The value is the SOLE entry of
# `authorization_servers` in the RFC 9728
# `/.well-known/oauth-protected-resource` document served by every
# resource server. It is also the issuer (`iss`) of every JWT the
# authority mints and the base URL of the standard OIDC discovery
# endpoints (`/.well-known/openid-configuration`, `/.well-known/jwks.json`)
# advertised by `GET /oauth/.well-known/openid-configuration`.
#
# Set this to the URL clients (e.g. `opencode mcp auth <server>`)
# actually use to reach the authority. For local development, the
# loopback origin works; for production, set it to the public origin
# behind your TLS-terminating reverse proxy. The value is published
# verbatim — there is no host rewriting.
#
# Examples:
#   local:   http://127.0.0.1:3002
#   prod:    https://auth.example.com
# MCP_AUTHORITY_URL=http://127.0.0.1:3002

# ---------- Authorization Code + PKCE (RFC 6749 §4.1 + RFC 7636) ----------
# Mounted on the same HTTP listener as the admin UI. The path is
# fixed at `/oauth/authorize` per the OIDC convention. The endpoint:
#   - validates `redirect_uri` against RFC 8252 §7.3 loopback forms
#     (http://127.0.0.1:*, http://[::1]:*, http://localhost:*) only;
#   - requires the standard `state` parameter (echoed back on success
#     and on redirect-based errors per RFC 6749 §4.1.1);
#   - requires explicit user consent before issuing a `code`;
#   - enforces `code_challenge_method=S256` (PKCE plain is forbidden
#     by OAuth 2.1).
#
# Pre-registered clients only — Dynamic Client Registration is out
# of scope. Operators that need public web clients must add a
# `redirectUris` column in a follow-up.
#
# The token endpoint (`POST /oauth/token`) accepts the
# `authorization_code` grant in addition to the legacy
# `client_credentials`, `password`, and `refresh_token` grants.
# One-time `code`s live in a short-lived in-memory map (60s TTL);
# restart loss is acceptable because clients retry the authorize
# round-trip.
#
# Resource server clients can complete the standard interactive flow
# via `opencode mcp auth <server>` against any pre-registered client.

# ---------- Resource server base URL (advertised in 401 + well-known) ----------
# The public base URL of THIS resource server, when it is also acting
# as one. When this authority ALSO serves a resource surface (e.g.
# the admin UI is consumed via the same process), the value is the
# public origin clients use to reach it. Used as the `resource` field
# in `/.well-known/oauth-protected-resource` and as the base of the
# 401 `WWW-Authenticate` header (per RFC 6750 §3 and RFC 9728 §5.1).
#
# When unset, the shared base falls back to the per-request `Host`
# header + `x-forwarded-proto` (suitable for loopback / dev).
# For production behind a TLS-terminating proxy, set this to the
# public origin explicitly.
#
# Examples:
#   local:   http://127.0.0.1:3002
#   prod:    https://mcp.example.com
# MCP_RESOURCE_SERVER_URL=http://127.0.0.1:3002

# ---------- Token issuance ----------
# Audience placed in issued access tokens. Resource servers must set
# their MCP_AUTHORITY_AUDIENCE to the same value.
# MCP_AUTHORITY_AUDIENCE=mcp-readonly-sql

# Optional fallback used only when MCP_AUTHORITY_AUDIENCE is unset.
# The issued audience becomes `mcp:${MCP_OAUTH_APP_ID}`.
# MCP_OAUTH_APP_ID=admin

# Default scope assigned by the token endpoint when a client or agent
# has no narrower configured scope.
# MCP_OAUTH_DEFAULT_SCOPE=read:bi_catastro

# ---------- Storage ----------
# SQLite database path. Default ./data/mcp-oauth.sqlite (relative
# to the process CWD). The parent directory is created on first
# start. WAL mode + foreign_keys are enabled on every connection.
# MCP_OAUTH_DB_PATH=/var/lib/mcp/oauth.sqlite

# Backup target. When set, the live database is copied to the
# target path on startup and every MCP_OAUTH_BACKUP_INTERVAL_S
# seconds (default 86400 = 24h). The target directory is created
# if missing. The live database continues to serve traffic
# during the backup; the user-visible target is always either
# the previous complete backup or the new complete backup — never
# a partial file.
# MCP_OAUTH_BACKUP_TARGET=/var/backups/mcp-oauth.sqlite
# MCP_OAUTH_BACKUP_INTERVAL_S=86400

# Daily retention sweep. The sweep deletes audit_log rows older
# than 90 days and revoked refresh_tokens older than 30 days.
# Set to "true" to skip the sweep entirely (defense-in-depth;
# the scheduler also honors this flag).
MCP_OAUTH_DISABLE_RETENTION_SWEEP=false

# ---------- Bootstrap admin ----------
# Read on first start to seed the admin user. The password is
# stored as argon2id and `require_change_on_first_login` is set,
# so the admin cannot mint tokens until the password is rotated.
# A WARN is logged while these env vars are set. The spec leaves
# the rotation policy to the operator; the admin UI handles the
# rotation flow.
# MCP_OAUTH_ADMIN_USERNAME=root
# MCP_OAUTH_ADMIN_PASSWORD=change_me_on_first_login
