{
  "name": "mcp-oauth-admin",
  "version": "0.1.0",
  "description": "OAuth2 Authorization Server + SQLite identity store + web admin UI for the customized-mcps workspace. Owns default scope assignment; resource servers consume only the wire contract.",
  "type": "module",
  "bin": {
    "mcp-oauth-admin": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:http": "MCP_TRANSPORT=streamableHttp tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "oauth2",
    "sqlite",
    "authorization-server",
    "oidc"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@customized-mcps/mcp-http-base": "workspace:*",
    "argon2": "^0.44.0",
    "jose": "^5.9.0",
    "knex": "^3.1.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
