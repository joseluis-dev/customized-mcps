{
  "name": "db-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for MCP server apps. This package is not deployable; each app under apps/ is its own package.",
  "scripts": {
    "dev": "pnpm --filter mcp-readonly-sql dev",
    "start": "pnpm --filter mcp-readonly-sql start",
    "inspect": "pnpm --filter mcp-readonly-sql inspect",
    "test:watch": "pnpm --filter mcp-readonly-sql test:watch",
    "test:apps": "pnpm --filter mcp-readonly-sql test",
    "test:packages": "pnpm --filter @customized-mcps/mcp-http-base test",
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "typecheck:apps": "pnpm --filter mcp-readonly-sql typecheck",
    "typecheck:packages": "pnpm --filter @customized-mcps/mcp-http-base typecheck",
    "typecheck": "pnpm -r --workspace-concurrency=1 run typecheck",
    "build:apps": "pnpm --filter mcp-readonly-sql build",
    "build:packages": "pnpm --filter @customized-mcps/mcp-http-base build",
    "build": "pnpm -r --workspace-concurrency=1 run build"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sqlite3"
    ]
  }
}
